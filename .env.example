# Copy this file to .env and fill in your real keys.
# Do not commit secrets.

# Preferred: comma-separated keys for automatic fallback
GEMINI_API_KEYS="your_key_1,your_key_2"

# Optional single-key fallback (used if GEMINI_API_KEYS is not set)
GEMINI_API_KEY="your_key"
GOOGLE_API_KEY="your_key"

# Optional chat model selection
GEMINI_CHAT_MODEL="gemini-2.0-flash"
GEMINI_CHAT_MODELS="gemini-2.0-flash,gemini-1.5-flash"

# Optional: enable runtime model discovery (slower startup if true)
GEMINI_DISCOVER_MODELS="false"

# Optional embedding model
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Optional OCR path override on Windows
TESSERACT_CMD="C:/Program Files/Tesseract-OCR/tesseract.exe"

# Optional: Poppler path for pdf2image (required for scanned PDF OCR on Windows)
# Download from: https://github.com/oschwartz10612/poppler-windows/releases
POPPLER_PATH="C:/Program Files/poppler/Library/bin"

# ChromaDB storage path (default: ./chroma)
CHROMA_PATH="chroma"

# Chunking parameters
CHUNK_SIZE="800"
CHUNK_OVERLAP="200"

# RAG retrieval tuning
RAG_TOP_K="5"                    # number of chunks to retrieve
RAG_MAX_CONTEXT_CHARS="6000"     # max total chars sent to LLM
RAG_MAX_CHUNK_CHARS="1200"       # max chars per individual chunk
RAG_RELEVANCE_THRESHOLD="1.5"   # L2 distance threshold (lower = stricter)

